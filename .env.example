# in_memory | postgres
STORAGE_BACKEND=postgres

# Supabase project
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Postgres connection string (Supabase Database URL)
SUPABASE_DB_URL=postgresql://postgres:password@db.YOUR_PROJECT.supabase.co:5432/postgres

# Super admin seed (all access)
SUPERADMIN_EMAIL=superadmin@dodream.local
SUPERADMIN_PASSWORD=ChangeMe123!
SUPERADMIN_NAME=슈퍼관리자
SUPERADMIN_TEAM=ops

# Optional: CORS origins (comma-separated)
# CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
