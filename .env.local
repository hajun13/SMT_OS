# Optional local overrides.
# 기본값은 `.env`를 사용합니다.
# 필요한 키만 아래에 추가해서 덮어쓰세요.
#
# STORAGE_BACKEND=postgres
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=...
# SUPABASE_SERVICE_ROLE_KEY=...
# SUPABASE_DB_URL=postgresql://postgres:...
# SUPERADMIN_EMAIL=superadmin@dodream.local
# SUPERADMIN_PASSWORD=...
# SUPERADMIN_NAME=슈퍼관리자
# SUPERADMIN_TEAM=ops
